class Solution:
    def getMaximumGold(self, grid: List[List[int]]) -> int:

        def dfs(row, col, total):
            self.ans = max(self.ans, total)

            for delrow, delcol in [(-1, 0), (0, -1), (1, 0), (0, 1)]:
                nrow = row + delrow
                ncol = col + delcol

                if nrow >= 0 and nrow < len(grid) and \
                  ncol >= 0 and ncol < len(grid[0]) and grid[nrow][ncol] != 0:
                    total += grid[nrow][ncol]
                    aux = grid[nrow][ncol]
                    grid[nrow][ncol] = 0
                    dfs(nrow, ncol, total)
                    total -= aux
                    grid[nrow][ncol] = aux

        self.ans = 0
        for row in range(len(grid)):
            for col in range(len(grid[0])):
                if grid[row][col] != 0:
                    aux = grid[row][col]
                    grid[row][col] = 0
                    dfs(row, col, aux)
                    grid[row][col] = aux

        return self.ans
        
